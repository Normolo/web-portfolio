---
import globalCss from '../styles/global.css?raw';
import { getCollection } from 'astro:content';
import { execFileSync } from 'node:child_process';
import { PROFILE_PHOTO_SRC } from '../lib/site';
import changelogEntries from '../data/changelog.json';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Personal portfolio — projects & photography' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

// ── git helpers ────────────────────────────────────────────────────────────

const env = import.meta.env as Record<string, string | undefined>;
const SHORT_SHA_LENGTH = 7;
const MAX_COMMITS_TO_SCAN = 20;
const SHA_REGEX = /^[0-9a-f]{40}$/i;
const BRANCH_REGEX = /^[A-Za-z0-9._/-]+$/;
const GIT_EXEC_OPTIONS = {
  cwd: process.cwd(),
  encoding: 'utf-8',
  stdio: ['ignore', 'pipe', 'pipe'] as const,
  timeout: 2000,
};

const readGitFullSha = () => {
  try {
    const sha = (execFileSync('git', ['rev-parse', 'HEAD'], GIT_EXEC_OPTIONS) as string).trim();
    return SHA_REGEX.test(sha) ? sha : undefined;
  } catch {
    return undefined;
  }
};

const readGitBranch = () => {
  try {
    const branch = (execFileSync('git', ['rev-parse', '--abbrev-ref', 'HEAD'], GIT_EXEC_OPTIONS) as string).trim();
    // 'HEAD' means detached HEAD state — not a useful display value
    if (branch === 'HEAD') return undefined;
    return BRANCH_REGEX.test(branch) ? branch : undefined;
  } catch {
    return undefined;
  }
};

const MERGE_PULL_REQUEST_REGEX = /Merge pull request #(\d+)/i;
const SQUASH_PULL_REQUEST_REGEX = /\(#(\d+)\)\s*$/;
// Unit Separator (U+001F) is safe to use as a field delimiter in git --pretty format
// because it cannot appear in a commit timestamp or message body.
const GIT_FIELD_SEP = '\x1f';

const extractPullRequestNumber = (message: string) => {
  const mergeMatch = message.match(MERGE_PULL_REQUEST_REGEX);
  if (mergeMatch?.[1]) return mergeMatch[1];
  const squashMatch = message.match(SQUASH_PULL_REQUEST_REGEX);
  return squashMatch?.[1];
};

// Scan recent commits for PR merge/squash patterns; returns { number, date } for the first hit.
const readGitLastPullRequest = (): { number: string; date: Date } | undefined => {
  try {
    // Format: <unix timestamp><GIT_FIELD_SEP><body>\x00 per commit
    const logOutput = (execFileSync(
      'git',
      ['log', '-n', String(MAX_COMMITS_TO_SCAN), `--pretty=%ct${GIT_FIELD_SEP}%B\x00`],
      GIT_EXEC_OPTIONS,
    ) as string);
    const commits = logOutput
      .split('\u0000')
      .map((chunk) => chunk.trim())
      .filter(Boolean);

    for (const chunk of commits) {
      const sep = chunk.indexOf(GIT_FIELD_SEP);
      if (sep === -1) continue;
      const ts = chunk.slice(0, sep).trim();
      const message = chunk.slice(sep + GIT_FIELD_SEP.length).trim();
      const prNumber = extractPullRequestNumber(message);
      if (prNumber) {
        const epoch = parseInt(ts, 10);
        return { number: prNumber, date: new Date(epoch * 1000) };
      }
    }
    return undefined;
  } catch {
    return undefined;
  }
};

// Cache the git PR result so we call git only once for both version and last-updated.
const gitLastPr = readGitLastPullRequest();

// ── version ────────────────────────────────────────────────────────────────

const fullCommitSha = env.CF_PAGES_COMMIT_SHA ?? env.GITHUB_SHA ?? readGitFullSha();
const shortCommitSha = fullCommitSha?.slice(0, SHORT_SHA_LENGTH) ?? 'unknown';

const GITHUB_REPO_REGEX = /^[A-Za-z0-9_.-]+\/[A-Za-z0-9_.-]+$/;
const GITHUB_PR_NUMBER_REGEX = /^\d+$/;
const KNOWN_GITHUB_REPOSITORY = 'Normolo/web-portfolio';

// Resolve branch name first — needed as input to the GitHub API PR lookup fallback.
const branchName =
  env.CF_PAGES_BRANCH ??
  env.GITHUB_HEAD_REF ??
  env.GITHUB_REF_NAME?.replace(/^refs\/heads\//, '') ??
  readGitBranch();

// Look up the open PR for a given branch via the GitHub API.
// Used as a final fallback when the build environment uses a shallow clone
// (depth=1) and CF_PAGES_PULL_REQUEST_ID is not set, making git-log-based
// detection unreliable for preview branch deployments.
const fetchGitHubPrNumberForBranch = async (branch: string): Promise<string | undefined> => {
  if (!BRANCH_REGEX.test(branch) || branch === 'main' || branch === 'master') return undefined;
  try {
    const repo = env.GITHUB_REPOSITORY ?? KNOWN_GITHUB_REPOSITORY;
    if (!GITHUB_REPO_REGEX.test(repo)) return undefined;
    const [owner] = repo.split('/');
    const resp = await fetch(
      `https://api.github.com/repos/${repo}/pulls?state=open&head=${owner}:${branch}&per_page=1`,
      { headers: { Accept: 'application/vnd.github+json', 'User-Agent': 'web-portfolio-build' } },
    );
    if (!resp.ok) return undefined;
    const data = (await resp.json()) as Array<{ number: number }>;
    return data[0]?.number?.toString();
  } catch {
    return undefined;
  }
};

const prNumber =
  env.CF_PAGES_PULL_REQUEST_ID ??
  env.GITHUB_REF?.match(/^refs\/pull\/(\d+)\/(?:head|merge)$/)?.[1] ??
  gitLastPr?.number ??
  (branchName ? await fetchGitHubPrNumberForBranch(branchName) : undefined);

const fetchGitHubPrIsDraft = async (pr: string): Promise<boolean> => {
  if (!GITHUB_PR_NUMBER_REGEX.test(pr)) return false;
  try {
    // GITHUB_REPOSITORY is set in GitHub Actions; fall back to the known repo name
    const repo = env.GITHUB_REPOSITORY ?? KNOWN_GITHUB_REPOSITORY;
    if (!GITHUB_REPO_REGEX.test(repo)) return false;
    const resp = await fetch(`https://api.github.com/repos/${repo}/pulls/${pr}`, {
      headers: { Accept: 'application/vnd.github+json', 'User-Agent': 'web-portfolio-build' },
    });
    if (!resp.ok) return false;
    const data = (await resp.json()) as { draft?: boolean };
    return data.draft === true;
  } catch {
    return false;
  }
};

const prIsDraft = prNumber ? await fetchGitHubPrIsDraft(prNumber) : false;

const versionId = prNumber
  ? `PR #${prNumber}${prIsDraft ? ' (Draft)' : ''} · ${shortCommitSha}`
  : branchName
    ? `${branchName} · ${shortCommitSha}`
    : shortCommitSha;

// ── last updated ───────────────────────────────────────────────────────────

const [projects, photos] = await Promise.all([
  getCollection('projects', ({ data }) => !data.draft),
  getCollection('photos', ({ data }) => !data.draft),
]);

const allEntries = [...projects, ...photos];
const contentTimestamps = allEntries.map((entry) => entry.data.date.getTime());
const lastPrDate = gitLastPr?.date;
const changelogLatestDate = (changelogEntries as Array<{ merged_at: string }>)[0]?.merged_at
  ? new Date((changelogEntries as Array<{ merged_at: string }>)[0].merged_at)
  : undefined;
const allTimestamps = [
  ...contentTimestamps,
  ...(lastPrDate ? [lastPrDate.getTime()] : []),
  ...(changelogLatestDate ? [changelogLatestDate.getTime()] : []),
];
const latestUpdateTimestamp = allTimestamps.length
  ? allTimestamps.reduce((latest, current) => Math.max(latest, current), 0)
  : null;

const latestUpdate = latestUpdateTimestamp ? new Date(latestUpdateTimestamp) : null;

const updatedAtIso = latestUpdate ? latestUpdate.toISOString() : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href={PROFILE_PHOTO_SRC} />
    <style set:html={globalCss}></style>
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <header>
      <a href="/" class="logo">Benjamin Borg</a>
      <div class="header-center">
        <a href="/" class="nav-home" aria-label="Home" aria-current={Astro.url.pathname === '/' ? 'page' : undefined}>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 10.8L12 3l9 7.8" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/>
            <path d="M6.5 10.2V21h11V10.2" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/>
          </svg>
        </a>
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
          <!-- Sun: shown in dark mode → click to go light -->
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="4" stroke="currentColor" strokeWidth="1.8"/>
            <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"/>
          </svg>
          <!-- Moon: shown in light mode → click to go dark -->
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"/>
          </svg>
        </button>
      </div>
      <nav>
        <a href="/projects" aria-current={Astro.url.pathname.startsWith('/projects') ? 'page' : undefined}>Projects</a>
        <a href="/skills" aria-current={Astro.url.pathname.startsWith('/skills') ? 'page' : undefined}>Skills</a>
        <a href="/cv" aria-current={Astro.url.pathname.startsWith('/cv') ? 'page' : undefined}>CV</a>
        <a href="/photography" aria-current={Astro.url.pathname.startsWith('/photography') ? 'page' : undefined}>Photography</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Benjamin Borg · Updated <time id="footer-updated" datetime={updatedAtIso ?? undefined}>–</time> · Version {versionId} · <a href="/changelog">Changelog</a></p>
    </footer>
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        var root = document.documentElement;

        function systemTheme() {
          return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }

        function effectiveTheme() {
          return root.dataset.theme || systemTheme();
        }

        function sync() {
          var isOverride = !!root.dataset.theme;
          var effective = effectiveTheme();
          if (isOverride) {
            btn.setAttribute('aria-label', 'Switch to system theme');
          } else {
            btn.setAttribute('aria-label', effective === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
          }
        }

        sync();

        btn.addEventListener('click', function () {
          if (root.dataset.theme) {
            // Currently overriding → return to auto/system
            delete root.dataset.theme;
            localStorage.removeItem('theme');
          } else {
            // Currently auto → override to opposite of system
            var override = systemTheme() === 'dark' ? 'light' : 'dark';
            root.dataset.theme = override;
            localStorage.setItem('theme', override);
          }
          sync();
        });

        // Keep aria-label in sync if system preference changes while in auto mode
        window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function () {
          if (!root.dataset.theme) sync();
        });
      })();

      // ── footer relative time ─────────────────────────────────────────────
      (function () {
        var el = document.getElementById('footer-updated');
        if (!el) return;
        var iso = el.getAttribute('datetime');
        if (!iso) { el.textContent = 'no updates yet'; return; }
        var date = new Date(iso);
        if (isNaN(date.getTime())) { el.textContent = 'no updates yet'; return; }

        var now = new Date();
        var diffDays = Math.max(0, Math.floor((now.getTime() - date.getTime()) / 86400000)); // ms per day

        var label;
        if (diffDays < 1) {
          label = 'today';
        } else if (diffDays === 1) {
          label = '1 day ago';
        } else if (diffDays < 30) {
          label = diffDays + ' days ago';
        } else {
          var diffMonths = Math.max(0,
            (now.getFullYear() - date.getFullYear()) * 12 +
            (now.getMonth() - date.getMonth()) -
            (now.getDate() < date.getDate() ? 1 : 0)
          );
          if (diffMonths === 0) { label = diffDays + ' days ago'; }
          else if (diffMonths === 1) { label = '1 month ago'; }
          else if (diffMonths < 12) { label = diffMonths + ' months ago'; }
          else {
            var diffYears = Math.floor(diffMonths / 12);
            label = diffYears === 1 ? '1 year ago' : diffYears + ' years ago';
          }
        }
        el.textContent = label;
      })();
    </script>
  </body>
</html>
