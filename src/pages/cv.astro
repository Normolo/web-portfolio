---
import Layout from '../layouts/Layout.astro';
---
<Layout title="CV | Benjamin Borg" description="Curriculum Vitae placeholder page.">
  <h1>Curriculum Vitae</h1>
  <p class="subtitle" style="color: var(--muted); margin-top: 0.25rem;">
    My Curriculum Vitae is available as a downloadable PDF.
  </p>

  <section class="card" style="margin-top: 1.5rem; text-align: center;">
    <h2 style="margin-top: 0;">PDF placeholder</h2>
    <p style="color: var(--muted); margin-bottom: 0;">
      Replace this placeholder with the final CV PDF embed or download link.
    </p>
  </section>
</Layout>
