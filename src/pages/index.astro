---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { thumbPath, buildSrcSet, CONTENT_MAX_VIEWPORT } from '../lib/img';
import { PROFILE_PHOTO_SRC } from '../lib/site';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const photos = (await getCollection('photos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const profilePhotoSrc = PROFILE_PHOTO_SRC;
const profilePhotoSrcSet = await buildSrcSet(profilePhotoSrc, [120, 240, 360]);

const projectPreviewSrcSets = new Map(
  await Promise.all(
    projects.map(async (p) => [p.id, p.data.image ? await buildSrcSet(p.data.image, [72, 144, 216]) : undefined] as const),
  ),
);

const homePhotoSrcSets = new Map(
  await Promise.all(
    photos.map(async (p) => [p.id, await buildSrcSet(p.data.cover, [390, 640, 828])] as const),
  ),
);

// Home page has two columns at ≥960px; each photo-grid section is ~390px wide (1-column grid).
// At narrower viewports it's full-width, similar to the gallery page.
const HOME_PHOTO_SIZES = `(min-width: 960px) 390px, (min-width: 520px) calc(50vw - 2rem), calc(100vw - 3rem)`;
---
<Layout title="Benjamin Borg">
  <div class="hero">
    <img
      class="profile-photo"
      src={profilePhotoSrc}
      alt="Benjamin Borg"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      srcset={profilePhotoSrcSet}
      sizes="120px"
      width="120"
      height="120"
    />
    <h1>Hey, I'm Benjamin Borg 👋</h1>
    <p class="subtitle">Mathematics and CS student working part-time in cutting-edge cybersecurity, aiming to pursue a career in quantum computer security.</p>
    <section class="contact-block">
      <h2>Contact</h2>
      <p>If you would like to connect regarding opportunities, projects, or collaboration, please reach out using one of the channels below.</p>
      <div class="contact-actions">
        <a
          class="contact-link linkedin"
          href="https://www.linkedin.com/in/benjamin-borg-0922722a8/"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="contact-icon-svg" aria-hidden="true">
            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zM4.943 13.5V6.169H2.542V13.5zM3.744 5.17c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.213 2.4 3.922c0 .694.507 1.248 1.327 1.248zm1.64 8.33h2.401V9.406c0-.219.016-.438.08-.594.175-.437.57-.89 1.236-.89.872 0 1.22.672 1.22 1.655V13.5h2.401V9.297c0-2.25-1.2-3.297-2.8-3.297-1.289 0-1.845.71-2.165 1.21h.03v-1.04H5.384c.03.679 0 7.33 0 7.33"/>
            </svg>
          </span>
          LinkedIn
        </a>
        <a
          class="contact-link github"
          href="https://github.com/Normolo"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="contact-icon-svg" aria-hidden="true">
            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <path d="M8 0a8 8 0 0 0-2.53 15.59c.4.074.547-.174.547-.386 0-.19-.007-.693-.01-1.36-2.226.483-2.695-1.073-2.695-1.073-.364-.924-.888-1.17-.888-1.17-.726-.496.055-.486.055-.486.802.057 1.224.823 1.224.823.713 1.221 1.87.868 2.327.664.072-.517.279-.869.508-1.068-1.777-.202-3.645-.889-3.645-3.956 0-.874.313-1.588.824-2.148-.082-.203-.357-1.015.079-2.116 0 0 .672-.215 2.2.82a7.7 7.7 0 0 1 4.004 0c1.528-1.035 2.199-.82 2.199-.82.437 1.101.162 1.913.08 2.116.513.56.823 1.274.823 2.148 0 3.075-1.87 3.752-3.652 3.95.287.247.543.735.543 1.482 0 1.07-.01 1.932-.01 2.194 0 .214.145.464.55.385A8 8 0 0 0 8 0"/>
            </svg>
          </span>
          GitHub
        </a>
        <button class="contact-link email" type="button" data-copy-email="me@b-borg.net">
          <span class="contact-icon" aria-hidden="true">@</span>
          Copy email
        </button>
      </div>
      <p class="contact-toast" id="contact-toast" role="status" aria-live="polite" hidden></p>
    </section>
  </div>

  <div class="home-sections">
    <!-- Projects -->
    <section class="home-section">
      <h2>Recent Projects</h2>
      <p style="color: var(--muted); font-size: 0.9rem;">A selection of things I've built or tinkered with.</p>
      <div class="card-grid">
        {projects.map(p => (
          <a href={`/projects/${p.id}`} style="text-decoration: none; color: inherit;">
            <div class="card" style={p.data.image ? "display: flex; gap: 0.85rem; align-items: flex-start; padding: 1rem 1.25rem;" : undefined}>
              {p.data.image && (
                <img
                  src={p.data.image}
                  alt={`Cover image for ${p.data.title}`}
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  srcset={projectPreviewSrcSets.get(p.id)}
                  sizes="72px"
                  width="72"
                  height="72"
                  style="width: 72px; height: 72px; object-fit: cover; border-radius: var(--radius); flex-shrink: 0;"
                />
              )}
              <div>
                <h3 style="margin-top: 0;">{p.data.title}</h3>
                <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 0.75rem;">{p.data.description}</p>
                <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
                  {p.data.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
      <p style="margin-top: 1.25rem;">
        <a class="section-link" href="/projects">All projects →</a>
      </p>
    </section>

    <!-- Photography -->
    <section class="home-section">
      <h2>Recent Photography</h2>
      <p style="color: var(--muted); font-size: 0.9rem;">Moments captured through a lens.</p>
      <div class="photo-grid">
        {photos.map(p => {
          const thumb = thumbPath(p.data.cover);
          return (
            <a href={`/photography/${p.id}`} class="photo-card" style="text-decoration: none; color: inherit;">
              <picture>
                {thumb && (
                  <source
                    type="image/webp"
                    srcset={`${thumb} 640w`}
                    sizes={HOME_PHOTO_SIZES}
                  />
                )}
                <img
                  src={p.data.cover}
                  srcset={homePhotoSrcSets.get(p.id)}
                  sizes={HOME_PHOTO_SIZES}
                  alt={p.data.title}
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                />
              </picture>
            </a>
          );
        })}
      </div>
      <p style="margin-top: 1.25rem;">
        <a class="section-link photo" href="/photography">Full gallery →</a>
        <a class="section-link photo" href="https://www.flickr.com/photos/202270807@N07/" target="_blank" rel="noopener noreferrer" style="margin-left: 0.6rem;">Flickr portfolio ↗</a>
      </p>
    </section>
  </div>
  <script is:inline>
    const emailButton = document.querySelector('[data-copy-email]');
    const toast = document.getElementById('contact-toast');

    const copyWithFallback = async (text) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const tempInput = document.createElement('textarea');
      tempInput.value = text;
      tempInput.setAttribute('readonly', '');
      tempInput.style.position = 'absolute';
      tempInput.style.left = '-9999px';
      document.body.appendChild(tempInput);
      tempInput.select();
      // Deprecated API used only as fallback when Clipboard API is unavailable.
      const copied = document.execCommand('copy');
      document.body.removeChild(tempInput);
      return copied;
    };

    if (emailButton && toast) {
      let hideTimer;

      emailButton.addEventListener('click', async () => {
        const email = emailButton.getAttribute('data-copy-email') ?? '';

        try {
          const copied = await copyWithFallback(email);
          if (!copied) throw new Error('copy failed');
          toast.textContent = 'Email copied to clipboard';
        } catch {
          toast.textContent = `Could not copy automatically. Email: ${email}`;
        }

        toast.hidden = false;
        toast.classList.add('visible');

        window.clearTimeout(hideTimer);
        hideTimer = window.setTimeout(() => {
          toast.classList.remove('visible');
          toast.hidden = true;
        }, 2200);
      });
    }
  </script>
</Layout>
