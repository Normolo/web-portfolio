---
import Layout from '../../layouts/Layout.astro';
import { skills } from '../../lib/skills';
---
<Layout title="Skills — Benjamin Borg" description="A summary of my core skills and focus areas.">
  <h1>Skills</h1>
  <p style="color: var(--muted); margin-top: 0.25rem;">A short overview of the areas I work in most.</p>

  {skills.map((skill) => (
    <section id={skill.slug} style="margin-top: 2rem; scroll-margin-top: 5rem;">
      <h2 style="margin-top: 0;">{skill.name}</h2>
      <p>{skill.description}</p>
    </section>
  ))}
</Layout>
