---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { buildSrcSet, CONTENT_MAX_VIEWPORT } from '../../lib/img';

export async function getStaticPaths() {
  const photos = await getCollection('photos', ({ data }) => !data.draft);
  return photos.map(p => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, cover, category } = entry.data;
const coverSrcSet = await buildSrcSet(cover, [600, 812, 1200]);
---
<Layout title={`${title} — Benjamin Borg Photography`} description={description ?? title}>
  <a class="back" href="/photography">← Back to gallery</a>

  <article>
    <div class="meta">
      {category} · {date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })}
    </div>
    <h1>{title}</h1>

    <img
      src={cover}
      alt={title}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      srcset={coverSrcSet}
      sizes={`(min-width: ${CONTENT_MAX_VIEWPORT}px) 812px, calc(100vw - 3rem)`}
      style="width: 100%; max-height: 520px; object-fit: cover; border-radius: var(--radius); margin: 1rem 0 1.5rem;"
    />

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>
