---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const photos = (await getCollection('photos', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = [...new Set(photos.map(p => p.data.category))];

function thumbPath(cover: string): string | null {
  if (!cover.startsWith('/photos/')) return null;
  const filename = cover.slice('/photos/'.length);
  const stem = filename.replace(/\.[^.]+$/, '');
  return `/photos/_thumbs/${stem}.webp`;
}
---
<Layout title="Photography — Benjamin Borg" description="Hobbyist photography — landscapes, street, and more.">
  <h1>Photography</h1>
  <p style="color: var(--muted); margin-top: 0.25rem;">A collection of photos I'm proud of.</p>

  {categories.map(cat => (
    <section style="margin-top: 2.5rem;">
      <h2 style="margin-top: 0;">{cat}</h2>
      <div class="photo-grid">
        {photos.filter(p => p.data.category === cat).map(p => {
          const thumb = thumbPath(p.data.cover);
          return (
            <a href={`/photography/${p.id}`} class="photo-card" style="text-decoration: none; color: inherit;">
              <picture>
                {thumb && (
                  <source
                    type="image/webp"
                    srcset={`${thumb} 640w`}
                    sizes="(min-width: 908px) 276px, (min-width: 520px) calc(50vw - 2rem), calc(100vw - 3rem)"
                  />
                )}
                <img src={p.data.cover} alt={p.data.title} loading="lazy" decoding="async" fetchpriority="low" />
              </picture>
            </a>
          );
        })}
      </div>
    </section>
  ))}
</Layout>
