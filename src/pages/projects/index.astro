---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { buildSrcSet, CONTENT_MAX_VIEWPORT } from '../../lib/img';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projectBannerSrcSets = new Map(
  await Promise.all(
    projects.map(async (p) => [p.id, p.data.image ? await buildSrcSet(p.data.image, [400, 800]) : undefined] as const),
  ),
);

// Card-grid is repeat(auto-fill, minmax(280px, 1fr)) inside 812px content area.
// Two 280px columns fit comfortably → each card ≈ 396px. One column on narrow screens.
const CARD_BANNER_SIZES = `(min-width: ${CONTENT_MAX_VIEWPORT}px) 396px, (min-width: 520px) calc(50vw - 2.25rem), calc(100vw - 3rem)`;
---
<Layout title="Projects — Benjamin Borg" description="A showcase of projects, experiments, and builds.">
  <h1>Projects</h1>
  <p style="color: var(--muted); margin-top: 0.25rem;">Things I've built, explored, or learned from.</p>

  <div class="card-grid">
    {projects.map(p => (
      <a href={`/projects/${p.id}`} style="text-decoration: none; color: inherit;">
        <div class="card" style="padding: 0; overflow: hidden;">
          {p.data.image && (
            <img
              src={p.data.image}
              alt={`Cover image for ${p.data.title}`}
              loading="lazy"
              decoding="async"
              srcset={projectBannerSrcSets.get(p.id) ?? undefined}
              sizes={CARD_BANNER_SIZES}
              style="width: 100%; height: 160px; object-fit: cover; display: block;"
            />
          )}
          <div style="padding: 1.25rem 1.5rem;">
            <div class="meta">{p.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}</div>
            <h3 style="margin-top: 0;">{p.data.title}</h3>
            <p style="color: var(--muted); font-size: 0.9rem; margin-bottom: 0.75rem;">{p.data.description}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
              {p.data.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>
