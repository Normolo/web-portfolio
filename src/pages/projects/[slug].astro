---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { skills as allSkills } from '../../lib/skills';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(p => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, date, tags, skills, repoUrl, liveUrl, image } = entry.data;
---
<Layout title={`${title} — Benjamin Borg`} description={description}>
  <a class="back" href="/projects">← Back to projects</a>

  <article>
    <div class="meta">
      {date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
    </div>
    <h1>{title}</h1>
    <p style="color: var(--muted); font-size: 1rem; margin-bottom: 1rem;">{description}</p>

    <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem;">
      {tags.map(t => <span class="tag">{t}</span>)}
    </div>

    {skills.length > 0 && (
      <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
        <span style="font-size: 0.8rem; color: var(--muted);">Skills:</span>
        {skills.map(slug => {
          const skill = allSkills.find(s => s.slug === slug);
          return skill ? (
            <a href={`/skills#${slug}`} class="section-link skill" style="font-size: 0.8rem;">{skill.name}</a>
          ) : null;
        })}
      </div>
    )}

    {(repoUrl || liveUrl) && (
      <div style="display: flex; gap: 0.75rem; margin-bottom: 2rem; flex-wrap: wrap;">
        {repoUrl && <a class="section-link" href={repoUrl} target="_blank" rel="noopener">GitHub →</a>}
        {liveUrl && <a class="section-link" href={liveUrl} target="_blank" rel="noopener">Live site →</a>}
      </div>
    )}

    <div class="prose">
      {image && (
        <figure style="margin: 0 0 2rem;">
          <img
            src={image}
            alt={`Cover image for ${title}`}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            style="width: 100%; border-radius: var(--radius); display: block;"
          />
        </figure>
      )}
      <Content />
    </div>
  </article>
</Layout>
