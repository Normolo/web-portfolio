---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 40vh; text-align: center; gap: 1.25rem; padding: 3rem 1rem;">
    <p style="font-size: 4rem; line-height: 1; font-weight: 700; color: var(--accent);">404</p>
    <h1 style="font-size: 1.5rem; font-weight: 600;">Page not found</h1>
    <p style="color: var(--muted); max-width: 36ch;">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" style="margin-top: 0.5rem; color: var(--accent); font-weight: 500; text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 1px;">← Back to home</a>
  </div>
</Layout>
